{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                created_date_time,\n                modification_date_time,\n                client_id,\n                client_name,\n                program_id,\n                object_operations\n            FROM subscription\n            WHERE ($1::text IS NULL OR client_id = $1)\n              AND ($1::text IS NULL OR client_name = $2)\n            ORDER BY created_date_time\n            OFFSET $3 LIMIT $4\n            ",
